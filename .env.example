# =============================================================================
# Zava Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your Azure resource values
# DO NOT commit .env with real credentials to source control

# Azure AI Foundry / Azure OpenAI
AZURE_AI_PROJECT_ENDPOINT="https://your-region.api.azureml.ms/discovery"
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-4o"

# Azure Computer Vision
AZURE_VISION_ENDPOINT="https://your-vision-service.cognitiveservices.azure.com/"

# Azure AI Foundry Agent IDs
# Create agents in Azure AI Foundry portal and paste IDs here
PARCEL_INTAKE_AGENT_ID="asst_xxxxxxxxxxxxxxxxxxxxx"
SORTING_FACILITY_AGENT_ID="asst_xxxxxxxxxxxxxxxxxxxxx"
DELIVERY_COORDINATION_AGENT_ID="asst_xxxxxxxxxxxxxxxxxxxxx"
DISPATCHER_AGENT_ID="asst_xxxxxxxxxxxxxxxxxxxxx"
DRIVER_AGENT_ID="asst_xxxxxxxxxxxxxxxxxxxxx"
OPTIMIZATION_AGENT_ID="asst_xxxxxxxxxxxxxxxxxxxxx"
CUSTOMER_SERVICE_AGENT_ID="asst_xxxxxxxxxxxxxxxxxxxxx"
FRAUD_RISK_AGENT_ID="asst_xxxxxxxxxxxxxxxxxxxxx"
IDENTITY_AGENT_ID="asst_xxxxxxxxxxxxxxxxxxxxx"

# Azure Cosmos DB Configuration
COSMOS_DB_ENDPOINT="https://your-cosmos-account.documents.azure.com:443/"
COSMOS_DB_DATABASE_NAME="logisticstracking"

# For local development: Use Azure CLI authentication (az login)
# For Azure deployment: Managed identity is used automatically
USE_MANAGED_IDENTITY="false"

# Suppress aiohttp connection warnings for cleaner output
PYTHONWARNINGS="ignore::ResourceWarning"

# Azure Maps (for route optimization)
AZURE_MAPS_SUBSCRIPTION_KEY="your-azure-maps-subscription-key"

# Azure Speech Services (for voice features)
AZURE_SPEECH_RESOURCE_ID="/subscriptions/xxx/resourceGroups/xxx/providers/Microsoft.CognitiveServices/accounts/xxx"
AZURE_SPEECH_ENDPOINT="https://your-speech-service.cognitiveservices.azure.com/"
AZURE_SPEECH_REGION="australiaeast"

# Voice Persona Selection (Optional - defaults to "natasha")
AZURE_SPEECH_VOICE="natasha"

# Depot/Warehouse Addresses by State
# Used as starting points for delivery route optimization
DEPOT_NSW="1 Homebush Bay Drive, Rhodes NSW 2138"
DEPOT_VIC="456 Spencer Street, Melbourne VIC 3000"
DEPOT_QLD="789 Creek Street, Brisbane QLD 4000"
DEPOT_SA="321 North Terrace, Adelaide SA 5000"
DEPOT_WA="654 Wellington Street, Perth WA 6000"
DEPOT_TAS="147 Elizabeth Street, Hobart TAS 7000"
DEPOT_ACT="258 Northbourne Avenue, Canberra ACT 2600"
DEPOT_NT="369 Mitchell Street, Darwin NT 0800"

# Flask Configuration
FLASK_SECRET_KEY="your-random-secret-key-change-in-production"
FLASK_ENV="development"
PORT="5000"

# Debug Mode (set to False in production)
DEBUG_MODE="True"

# Azure App Service Configuration for DT Logistics

# Python version
PYTHON_VERSION=3.11

# Startup command
STARTUP_COMMAND=gunicorn --bind=0.0.0.0:8000 --timeout 600 --workers=4 --threads=2 --worker-class=gthread app:app

# Environment variables (set these in Azure Portal)
# COSMOS_CONNECTION_STRING=<your_cosmos_connection_string>
# AZURE_AI_PROJECT_CONNECTION_STRING=<your_ai_project_connection_string>
# FLASK_SECRET_KEY=<generate_a_secure_random_key>
# FLASK_ENV=production

# App Service Settings
SCM_DO_BUILD_DURING_DEPLOYMENT=true
ENABLE_ORYX_BUILD=true
POST_BUILD_COMMAND=echo "Build completed"

# Logging
LOGGING_LEVEL=INFO
